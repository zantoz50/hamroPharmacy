# Server
PORT=3000
CORS_ORIGIN=*

# MongoDB - you can set MONGO_URI to full connection string or use host/port/db
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=hamroPharacy
MONGO_URI=

# JWT
JWT_SECRET=change_this_secret
JWT_EXPIRES=1d

# Admin seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=info
